                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "v1:campaign"
                ],
                "summary": "Update Status",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Campaign ID",
                        "name": "campaignID",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "New campaign status",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/campaign.UpdateCampaignStatusRequest"
