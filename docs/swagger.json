        "/core/api/v1/campaign/{campaignID}/status": {
            "patch": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Updates campaign status to the following rules:\n- **DRAFT** -\u003e ACTIVE\n- **ACTIVE** -\u003e PAUSED / ARCHIVED\n- **PAUSED** -\u003e ACTIVE / ARCHIVED",
